<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vsl_transport_stop_tree" model="ir.ui.view">
        <field name="name">vsl.transport.stop.tree</field>
        <field name="model">vsl.transport.stop</field>
        <field name="arch" type="xml">
            <list string="Duraklar">
                <field name="sequence" widget="handle"/>
                <field name="stop_type"/>
                <field name="address_id"/>
                <field name="planned_date"/>
                <field name="actual_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_vsl_transport_stop_form" model="ir.ui.view">
        <field name="name">vsl.transport.stop.form</field>
        <field name="model">vsl.transport.stop</field>
        <field name="arch" type="xml">
            <form string="Durak">
                <sheet>
                    <group>
                        <field name="stop_type"/>
                        <field name="sequence"/>
                        <field name="address_id"/>
                        <field name="planned_date"/>
                        <field name="actual_date"/>
                        <field name="state"/>
                    </group>
                    <group string="Durak Kalemleri">
                        <field name="line_ids"/>
                    </group>
                    <group string="Notlar">
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vsl_transport_stop_line_tree" model="ir.ui.view">
        <field name="name">vsl.transport.stop.line.tree</field>
        <field name="model">vsl.transport.stop.line</field>
        <field name="arch" type="xml">
            <list string="Durak Kalemleri">
                <field name="customer_id"/>
                <field name="product_desc"/>
                <field name="quantity"/>
                <field name="weight"/>
            </list>
        </field>
    </record>

    <record id="view_vsl_transport_stop_line_form" model="ir.ui.view">
        <field name="name">vsl.transport.stop.line.form</field>
        <field name="model">vsl.transport.stop.line</field>
        <field name="arch" type="xml">
            <form string="Durak Kalemi">
                <sheet>
                    <group>
                        <field name="customer_id"/>
                        <field name="product_desc"/>
                        <field name="quantity"/>
                        <field name="weight"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
