<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Demo Müşteriler -->
    <record id="demo_customer_1" model="res.partner">
        <field name="name">Anadolu Lojistik A.Ş.</field>
        <field name="street">Sanayi Cad. No:42</field>
        <field name="city">İstanbul</field>
        <field name="phone">0212 555 10 10</field>
    </record>

    <record id="demo_customer_2" model="res.partner">
        <field name="name">Ege Tarım Ürünleri Ltd.</field>
        <field name="street">Liman Sk. No:15</field>
        <field name="city">İzmir</field>
        <field name="phone">0232 444 20 20</field>
    </record>

    <record id="demo_customer_3" model="res.partner">
        <field name="name">Karadeniz İnşaat San. Tic.</field>
        <field name="street">Sahil Bulvarı No:88</field>
        <field name="city">Trabzon</field>
        <field name="phone">0462 333 30 30</field>
    </record>

    <!-- Demo Nakliyeciler -->
    <record id="demo_carrier_1" model="res.partner">
        <field name="name">Yılmaz Nakliyat</field>
        <field name="is_carrier" eval="True"/>
        <field name="phone">0532 111 22 33</field>
    </record>

    <record id="demo_carrier_2" model="res.partner">
        <field name="name">Asya Transport</field>
        <field name="is_carrier" eval="True"/>
        <field name="phone">0533 444 55 66</field>
    </record>

    <!-- Demo Adresler -->
    <record id="demo_address_1" model="res.partner">
        <field name="name">Depo - İstanbul/Hadımköy</field>
        <field name="type">delivery</field>
        <field name="city">İstanbul</field>
    </record>

    <record id="demo_address_2" model="res.partner">
        <field name="name">Fabrika - Ankara/Sincan</field>
        <field name="type">delivery</field>
        <field name="city">Ankara</field>
    </record>

    <record id="demo_address_3" model="res.partner">
        <field name="name">Mağaza - İzmir/Bornova</field>
        <field name="type">delivery</field>
        <field name="city">İzmir</field>
    </record>

    <record id="demo_address_4" model="res.partner">
        <field name="name">Şantiye - Trabzon/Akçaabat</field>
        <field name="type">delivery</field>
        <field name="city">Trabzon</field>
    </record>

    <record id="demo_address_5" model="res.partner">
        <field name="name">Depo - Bursa/Gemlik</field>
        <field name="type">delivery</field>
        <field name="city">Bursa</field>
    </record>

    <!-- ==================== Sevkiyat Emirleri ==================== -->

    <!-- 1: Teslim edilmiş, faturalanmış -->
    <record id="demo_order_1" model="vsl.transport.order">
        <field name="name">SEVK/2026/0001</field>
        <field name="customer_id" ref="demo_customer_1"/>
        <field name="state">invoiced</field>
        <field name="planned_date_start">2026-04-10 08:00:00</field>
        <field name="planned_date_end">2026-04-12 18:00:00</field>
        <field name="actual_date_start">2026-04-10 09:30:00</field>
        <field name="actual_date_end">2026-04-12 14:20:00</field>
        <field name="amount_total">18500.00</field>
        <field name="notes">İstanbul'dan İzmir'e komple tır nakliyesi. 24 palet tekstil ürünü.</field>
    </record>

    <!-- 2: Yolda -->
    <record id="demo_order_2" model="vsl.transport.order">
        <field name="name">SEVK/2026/0002</field>
        <field name="customer_id" ref="demo_customer_2"/>
        <field name="state">in_transit</field>
        <field name="planned_date_start">2026-05-01 06:00:00</field>
        <field name="planned_date_end">2026-05-03 17:00:00</field>
        <field name="actual_date_start">2026-05-01 07:15:00</field>
        <field name="amount_total">22500.00</field>
        <field name="notes">İzmir'den Ankara'ya soğuk zincir gıda nakliyesi. Frigorifik araç.</field>
    </record>

    <!-- 3: Yüklemede -->
    <record id="demo_order_3" model="vsl.transport.order">
        <field name="name">SEVK/2026/0003</field>
        <field name="customer_id" ref="demo_customer_3"/>
        <field name="state">loading</field>
        <field name="planned_date_start">2026-05-05 08:00:00</field>
        <field name="planned_date_end">2026-05-07 18:00:00</field>
        <field name="actual_date_start">2026-05-05 08:45:00</field>
        <field name="amount_total">32000.00</field>
        <field name="notes">Trabzon'dan İstanbul'a inşaat malzemesi (çelik konstrüksiyon). Ağır yük.</field>
    </record>

    <!-- 4: Atandı -->
    <record id="demo_order_4" model="vsl.transport.order">
        <field name="name">SEVK/2026/0004</field>
        <field name="customer_id" ref="demo_customer_1"/>
        <field name="state">open</field>
        <field name="planned_date_start">2026-05-08 07:00:00</field>
        <field name="planned_date_end">2026-05-09 20:00:00</field>
        <field name="amount_total">12750.00</field>
        <field name="notes">Bursa'dan Ankara'ya otomotiv yedek parça. 12 palet.</field>
    </record>

    <!-- 5: Açık, atama bekliyor -->
    <record id="demo_order_5" model="vsl.transport.order">
        <field name="name">SEVK/2026/0005</field>
        <field name="customer_id" ref="demo_customer_2"/>
        <field name="state">open</field>
        <field name="planned_date_start">2026-05-12 08:00:00</field>
        <field name="planned_date_end">2026-05-14 18:00:00</field>
        <field name="amount_total">41000.00</field>
        <field name="notes">İstanbul'dan Trabzon'a mobilya nakliyesi. 18 palet, hasarsız taşıma.</field>
    </record>

    <!-- 6: Taslak -->
    <record id="demo_order_6" model="vsl.transport.order">
        <field name="name">SEVK/2026/0006</field>
        <field name="customer_id" ref="demo_customer_3"/>
        <field name="state">draft</field>
        <field name="planned_date_start">2026-05-18 08:00:00</field>
        <field name="planned_date_end">2026-05-20 18:00:00</field>
        <field name="amount_total">9700.00</field>
        <field name="notes">Ankara'dan Bursa'ya kimyasal ürün (ADRsiz).</field>
    </record>

    <!-- 7: İptal edilmiş -->
    <record id="demo_order_7" model="vsl.transport.order">
        <field name="name">SEVK/2026/0007</field>
        <field name="customer_id" ref="demo_customer_1"/>
        <field name="state">cancelled</field>
        <field name="planned_date_start">2026-04-25 08:00:00</field>
        <field name="planned_date_end">2026-04-27 18:00:00</field>
        <field name="amount_total">15500.00</field>
        <field name="notes">Müşteri iptal etti — araç bulunamadı.</field>
    </record>

    <!-- ==================== Duraklar ==================== -->

    <!-- Sevkiyat 1 durakları -->
    <record id="demo_stop_1a" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_1"/>
        <field name="stop_type">loading</field>
        <field name="address_id" ref="demo_address_1"/>
        <field name="sequence">10</field>
        <field name="state">done</field>
        <field name="planned_date">2026-04-10 08:00:00</field>
        <field name="actual_date">2026-04-10 09:30:00</field>
    </record>
    <record id="demo_stop_1b" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_1"/>
        <field name="stop_type">unloading</field>
        <field name="address_id" ref="demo_address_3"/>
        <field name="sequence">20</field>
        <field name="state">done</field>
        <field name="planned_date">2026-04-12 10:00:00</field>
        <field name="actual_date">2026-04-12 14:20:00</field>
    </record>

    <!-- Sevkiyat 2 durakları (parsiyel yükleme) -->
    <record id="demo_stop_2a" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_2"/>
        <field name="stop_type">loading</field>
        <field name="address_id" ref="demo_address_3"/>
        <field name="sequence">10</field>
        <field name="state">done</field>
        <field name="planned_date">2026-05-01 06:00:00</field>
        <field name="actual_date">2026-05-01 07:15:00</field>
    </record>
    <record id="demo_stop_2b" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_2"/>
        <field name="stop_type">loading</field>
        <field name="address_id" ref="demo_address_5"/>
        <field name="sequence">15</field>
        <field name="state">done</field>
        <field name="planned_date">2026-05-02 08:00:00</field>
    </record>
    <record id="demo_stop_2c" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_2"/>
        <field name="stop_type">unloading</field>
        <field name="address_id" ref="demo_address_2"/>
        <field name="sequence">20</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-03 12:00:00</field>
    </record>

    <!-- Sevkiyat 3 durakları -->
    <record id="demo_stop_3a" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_3"/>
        <field name="stop_type">loading</field>
        <field name="address_id" ref="demo_address_4"/>
        <field name="sequence">10</field>
        <field name="state">done</field>
        <field name="planned_date">2026-05-05 08:00:00</field>
        <field name="actual_date">2026-05-05 08:45:00</field>
    </record>
    <record id="demo_stop_3b" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_3"/>
        <field name="stop_type">unloading</field>
        <field name="address_id" ref="demo_address_1"/>
        <field name="sequence">20</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-07 10:00:00</field>
    </record>

    <!-- Sevkiyat 4 durakları -->
    <record id="demo_stop_4a" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_4"/>
        <field name="stop_type">loading</field>
        <field name="address_id" ref="demo_address_5"/>
        <field name="sequence">10</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-08 07:00:00</field>
    </record>
    <record id="demo_stop_4b" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_4"/>
        <field name="stop_type">unloading</field>
        <field name="address_id" ref="demo_address_2"/>
        <field name="sequence">20</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-09 16:00:00</field>
    </record>

    <!-- Sevkiyat 5 durakları -->
    <record id="demo_stop_5a" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_5"/>
        <field name="stop_type">loading</field>
        <field name="address_id" ref="demo_address_1"/>
        <field name="sequence">10</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-12 08:00:00</field>
    </record>
    <record id="demo_stop_5b" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_5"/>
        <field name="stop_type">unloading</field>
        <field name="address_id" ref="demo_address_4"/>
        <field name="sequence">20</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-14 10:00:00</field>
    </record>

    <!-- Sevkiyat 6 durakları -->
    <record id="demo_stop_6a" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_6"/>
        <field name="stop_type">loading</field>
        <field name="address_id" ref="demo_address_2"/>
        <field name="sequence">10</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-18 08:00:00</field>
    </record>
    <record id="demo_stop_6b" model="vsl.transport.stop">
        <field name="order_id" ref="demo_order_6"/>
        <field name="stop_type">unloading</field>
        <field name="address_id" ref="demo_address_5"/>
        <field name="sequence">20</field>
        <field name="state">pending</field>
        <field name="planned_date">2026-05-20 10:00:00</field>
    </record>

    <!-- ==================== Araç Atamaları ==================== -->

    <!-- Sevkiyat 1 ataması -->
    <record id="demo_assign_1" model="vsl.vehicle.assignment">
        <field name="order_id" ref="demo_order_1"/>
        <field name="external_vehicle_plate">06TR345</field>
        <field name="driver_id" ref="demo_carrier_1"/>
        <field name="state">completed</field>
    </record>

    <!-- Sevkiyat 2 ataması -->
    <record id="demo_assign_2" model="vsl.vehicle.assignment">
        <field name="order_id" ref="demo_order_2"/>
        <field name="external_vehicle_plate">35AB789</field>
        <field name="driver_id" ref="demo_carrier_2"/>
        <field name="state">departed</field>
    </record>

    <!-- Sevkiyat 3 ataması -->
    <record id="demo_assign_3" model="vsl.vehicle.assignment">
        <field name="order_id" ref="demo_order_3"/>
        <field name="external_vehicle_plate">61YZ123</field>
        <field name="driver_id" ref="demo_carrier_1"/>
        <field name="state">assigned</field>
    </record>

    <!-- Sevkiyat 4 ataması -->
    <record id="demo_assign_4" model="vsl.vehicle.assignment">
        <field name="order_id" ref="demo_order_4"/>
        <field name="external_vehicle_plate">16LM456</field>
        <field name="driver_id" ref="demo_carrier_2"/>
        <field name="state">assigned</field>
    </record>

    <!-- Sevkiyat 4 durumunu atamadan sonra güncelle -->
    <function model="vsl.transport.order" name="write">
        <value eval="[ref('demo_order_4')]"/>
        <value eval="{'state': 'assigned'}"/>
    </function>

</odoo>
