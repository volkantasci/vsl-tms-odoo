<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vsl_transport_document_list" model="ir.ui.view">
        <field name="name">vsl.transport.document.list</field>
        <field name="model">vsl.transport.document</field>
        <field name="arch" type="xml">
            <list string="Sevkiyat Evrakları" editable="bottom">
                <field name="doc_type_id"/>
                <field name="datas" widget="binary"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="state" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_vsl_transport_document_form" model="ir.ui.view">
        <field name="name">vsl.transport.document.form</field>
        <field name="model">vsl.transport.document</field>
        <field name="arch" type="xml">
            <form string="Sevkiyat Evrağı">
                <sheet>
                    <group>
                        <field name="order_id"/>
                        <field name="doc_type_id"/>
                        <field name="datas" widget="binary"/>
                        <field name="issue_date"/>
                        <field name="expiry_date"/>
                        <field name="state" readonly="1"/>
                    </group>
                    <group string="Notlar">
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vsl_transport_document" model="ir.actions.act_window">
        <field name="name">Sevkiyat Evrakları</field>
        <field name="res_model">vsl.transport.document</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>