<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vsl_transport_order_tree" model="ir.ui.view">
        <field name="name">vsl.transport.order.tree</field>
        <field name="model">vsl.transport.order</field>
        <field name="arch" type="xml">
            <list string="Sevkiyat Emirleri" decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'invoiced'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="customer_order_ref"/>
                <field name="requested_vehicle_type_id"/>
                <field name="loading_location_id"/>
                <field name="unloading_location_id"/>
                <field name="state" widget="badge"/>
                <field name="planned_date_start"/>
                <field name="planned_date_end"/>
                <field name="amount_total" sum="Total"/>
                <field name="dispatch_note_display" string="İrsaliye"
                        decoration-success="dispatch_note_display == 'EVET'"
                        decoration-danger="dispatch_note_display == 'HAYIR'"
                        widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_vsl_transport_order_form" model="ir.ui.view">
        <field name="name">vsl.transport.order.form</field>
        <field name="model">vsl.transport.order</field>
        <field name="arch" type="xml">
            <form string="Sevkiyat Emri">
                <header>
                    <button name="action_confirm" type="object"
                            string="Onayla" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_open_assignment_wizard" type="object"
                            string="Pozisyon Bilgileri" class="btn-primary"
                            invisible="state != 'open'"/>
                    <button name="action_start_loading" type="object"
                            string="Yüklemeye Başla" class="btn-primary"
                            invisible="state != 'assigned'"/>
                    <button name="action_depart" type="object"
                            string="Yola Çıktı" class="btn-primary"
                            invisible="state != 'loading'"/>
                    <button name="action_deliver" type="object"
                            string="Teslim Et" class="btn-primary"
                            invisible="state != 'in_transit'"/>
                    <button name="%(action_vsl_transport_invoice_wizard)d" type="action"
                            string="Fatura Oluştur" class="btn-success"
                            invisible="state != 'delivered'"/>
                    <button name="%(action_vsl_transport_invoice_wizard)d" type="action"
                            string="Yeniden Fatura Oluştur" class="btn-warning"
                            invisible="state != 'invoiced'"/>
                    <button name="action_view_history" type="object"
                            string="Geçmiş" class="btn-secondary"
                            invisible="state in ('draft', 'open')"/>
                    <button name="action_cancel" type="object"
                            string="İptal" class="btn-danger"
                            invisible="state in ('delivered', 'invoiced', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,assigned,loading,in_transit,delivered,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Müşteri ve Tarihler">
                            <field name="customer_id"/>
                            <field name="customer_order_ref"/>
                            <field name="requested_vehicle_type_id"/>
                            <field name="planned_date_start"/>
                            <field name="planned_date_end"/>
                        </group>
                        <group string="Tutar ve Gerçekleşen">
                            <field name="amount_total" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="actual_date_start" readonly="1"/>
                            <field name="actual_date_end" readonly="1"/>
                        </group>
                    </group>
                    <group string="Pozisyon Bilgileri" invisible="not assignment_ids">
                        <field name="assignment_ids" options="{'no_open': True}">
                            <list create="true" edit="true" delete="true">
                                <field name="driver_id"/>
                                <field name="vehicle_id"/>
                                <field name="external_vehicle_plate"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </group>
                    <group string="Duraklar (Yükleme / Boşaltma)">
                        <field name="stop_ids"/>
                    </group>
                    <group string="Evraklar">
                        <field name="document_ids"/>
                    </group>
                    <group string="Notlar">
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vsl_transport_order_search" model="ir.ui.view">
        <field name="name">vsl.transport.order.search</field>
        <field name="model">vsl.transport.order</field>
        <field name="arch" type="xml">
            <search string="Sevkiyat Ara">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="customer_order_ref"/>
                            <field name="requested_vehicle_type_id"/>
                <filter name="draft" string="Taslak" domain="[('state', '=', 'draft')]"/>
                <filter name="open" string="Açık" domain="[('state', '=', 'open')]"/>
                <filter name="assigned" string="Atandı" domain="[('state', '=', 'assigned')]"/>
                <filter name="loading" string="Yüklemede" domain="[('state', '=', 'loading')]"/>
                <filter name="in_transit" string="Yolda" domain="[('state', '=', 'in_transit')]"/>
                <filter name="delivered" string="Teslim Edildi" domain="[('state', '=', 'delivered')]"/>
                <filter name="invoiced" string="Faturalandı" domain="[('state', '=', 'invoiced')]"/>
                <separator/>
                <filter name="active" string="Aktif"
                        domain="[('state', 'not in', ['cancelled', 'invoiced'])]"/>
                <group>
                    <filter name="group_state" context="{'group_by': 'state'}" string="Durum"/>
                    <filter name="group_customer" context="{'group_by': 'customer_id'}" string="Müşteri"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
