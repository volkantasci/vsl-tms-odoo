<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="menu_vsl_transport_root"
              name="Sevkiyatlar"
              web_icon="vsl_transport,static/description/icon.png"
              sequence="90"/>

    <record id="action_vsl_transport_order" model="ir.actions.act_window">
        <field name="name">Sevkiyat Emirleri</field>
        <field name="res_model">vsl.transport.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_vsl_transport_order_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Henüz bir sevkiyat emri yok.</p>
            <p>Yukarıdaki <strong>Yeni</strong> butonuna tıklayarak ilk sevkiyat emrinizi oluşturun.</p>
        </field>
    </record>

    <menuitem id="menu_vsl_transport_order"
              name="Sevkiyat Emirleri"
              parent="menu_vsl_transport_root"
              action="action_vsl_transport_order"
              sequence="10"/>

    <record id="action_vsl_vehicle_assignment" model="ir.actions.act_window">
        <field name="name">Pozisyonlar</field>
        <field name="res_model">vsl.vehicle.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vsl_vehicle_assignment"
              name="Pozisyonlar"
              parent="menu_vsl_transport_root"
              action="action_vsl_vehicle_assignment"
              sequence="20"/>

    <menuitem id="menu_vsl_transport_config"
              name="Yapılandırma"
              parent="menu_vsl_transport_root"
              sequence="90"/>

    <menuitem id="menu_vsl_config_vehicles"
              name="Araçlar"
              parent="menu_vsl_transport_config"
              action="fleet.fleet_vehicle_action"
              sequence="10"/>

    <menuitem id="menu_vsl_config_suppliers"
              name="Tedarikçiler"
              parent="menu_vsl_transport_config"
              action="account.res_partner_action_supplier"
              sequence="20"/>

    <menuitem id="menu_vsl_config_customers"
              name="Müşteriler"
              parent="menu_vsl_transport_config"
              action="account.res_partner_action_customer"
              sequence="30"/>

</odoo>
