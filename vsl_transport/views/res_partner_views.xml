<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_search_inherit" model="ir.ui.view">
        <field name="name">res.partner.search.inherit.transport</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <search>
                <filter name="only_companies" string="Şirketler" domain="[('parent_id', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="view_partner_form_inherit_transport" model="ir.ui.view">
        <field name="name">res.partner.form.transport</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Evraklar" name="carrier_documents">
                    <field name="carrier_document_ids"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
